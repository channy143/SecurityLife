# Supabase Configuration
# Copy this file to .env and fill in your Supabase credentials
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# SMTP Backend API (Optional - for real email MFA)
# To enable real email OTP, start the SMTP server (see server/ folder)
# VITE_SMTP_API_URL=http://localhost:3001
